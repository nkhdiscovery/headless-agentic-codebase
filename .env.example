# Copy to .env and customise. Never commit .env.

# --- Agent configuration ---

# Which Claude model the agent uses.
# claude-opus-4-7   = best, slower, most quota — default
# claude-sonnet-4-6 = fast, cheap, good for routine tasks
AGENT_MODEL=claude-opus-4-7

# How long the agent waits between cycles when queue is empty.
# Lower = more responsive to new issues, higher = less quota burn.
AGENT_IDLE_SECONDS=600

# --- Monitoring (all optional — agent works fine with these unset) ---

# healthchecks.io dead-man's switch. Agent pings this URL every cycle; if
# pings stop for >2× AGENT_IDLE_SECONDS, healthchecks.io emails/SMS/Slacks you.
# Free tier at https://healthchecks.io — create a check, paste the ping URL here.
# Set the check's period to AGENT_IDLE_SECONDS and grace period to 2× that.
HEALTHCHECKS_URL=

# ntfy.sh push notifications to your phone. Pick any unguessable topic name
# (it acts as a password). Subscribe in the ntfy app with the same topic.
# Free, no account needed: https://ntfy.sh
# Self-hosted: set NTFY_SERVER to your instance URL (default: https://ntfy.sh).
NTFY_TOPIC=
NTFY_SERVER=https://ntfy.sh

# GitHub-native heartbeat. Set to 1 to update .agent/heartbeat in the repo
# via the GitHub API every cycle. Visible in the repo's commit history on mobile.
# Trade-offs: adds one commit-per-cycle to the default branch; requires no
# external services; slower than ntfy for real-time activity.
# Use alongside healthchecks.io + ntfy for belt-and-suspenders observability,
# or alone when you prefer zero external dependencies.
AGENT_GITHUB_HEARTBEAT=

# --- Project-specific (add as needed) ---
# DATABASE_URL=
# API_KEY=
